{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd transitdb/backend && npm ci"
  },
  "deploy": {
    "startCommand": "cd transitdb/backend && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "env": {
      "DATABASE_URL": "${{ services.mysql.DATABASE_URL }}",
      "PORT": "5000",
      "JWT_SECRET": "change-this-in-railway-dashboard-to-a-secure-value",
      "JWT_EXPIRES_IN": "7d",
      "NODE_ENV": "production"
    }
  }
}
